# 龙门客栈 .gitignore
# 版本: v2.0（2026-03-31 安全修复 + 数据架构重构）

# === 数据库文件（本地开发数据，不上传）===
*.db
*.sqlite
*.sqlite3
*.db-journal
# 但保留模板文件
!data/templates/*.db

# === 运行时数据目录 ===
data/runtime/
*.tmp
*.temp

# === 依赖目录 ===
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
.venv/

# === 环境变量与敏感文件 ===
.env
.env.*
*.env
.env.local
.env.*.local
# 明确排除 backend/.env（含 SECRET_KEY 等敏感信息）
backend/.env
backend/.env.*
secrets.json
credentials.json
*.pem
*.key

# === IDE与编辑器 ===
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === 构建产物 ===
dist/
build/
*.egg-info/
.eggs/

# === 日志文件 ===
*.log
logs/

# === 个人工作记忆 ===
roles/*/MEMORY_LOG.md

# === 测试覆盖率 ===
htmlcov/
.coverage
.pytest_cache/
coverage.xml

# === 打包文件 ===
*.zip
*.tar.gz
*.rar

# === 本地备份目录 ===
backups/

# === 本地 IDE Job 标记文件 ===
#（由 IDE 插件生成，记录后台任务状态，不需要版本控制）
.backend_job
.frontend_job

# === AI 日常报告（个人每日工作记录，不需要上传）===
ai-daily-reports/

# === 项目交付物（本地验证产物，不需要上传）===
deliverables/
